# Add the following 'secrets' and 'environment' to the coturn container_definitions in ecs-services.tf
# (Find aws_ecs_task_definition.coturn and extend its container JSON)

"secrets": [
  { "name": "TURN_USER", "valueFrom": "${aws_secretsmanager_secret.turn.arn}:user::" },
  { "name": "TURN_PASS", "valueFrom": "${aws_secretsmanager_secret.turn.arn}:pass::" },
  { "name": "TURN_CERT_PEM", "valueFrom": "${aws_secretsmanager_secret.turn.arn}:cert_pem::" },
  { "name": "TURN_KEY_PEM",  "valueFrom": "${aws_secretsmanager_secret.turn.arn}:key_pem::" }
],
"environment": [
  { "name": "TURN_REALM", "value": "${aws_ssm_parameter.turn_realm.value}" }
],
"command": ["/bin/sh","-lc",
  "printf "$TURN_CERT_PEM" > /tmp/turn_cert.pem &&    printf "$TURN_KEY_PEM"  > /tmp/turn_key.pem &&    turnserver -n --log-file=stdout      --realm=$TURN_REALM      --lt-cred-mech --user=$TURN_USER:$TURN_PASS      --listening-port=3478      --tls-listening-port=5349      --cert=/tmp/turn_cert.pem --pkey=/tmp/turn_key.pem      --fingerprint --no-cli --no-tlsv1 --no-tlsv1_1"
]
