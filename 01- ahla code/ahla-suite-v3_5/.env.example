# ===== Dev defaults =====
WHISPER_BASE_URL=http://whisper:2022/v1
PIPER_HTTP_URL=http://piper:5500
XTTS_URL=http://xtts:8020
KAFKA_BROKERS=redpanda:9092
KAFKA_SASL_MECHANISM=none
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# ===== Prod (MSK IAM) =====
AWS_REGION=me-central-1
MSK_BOOTSTRAP=broker-1.msk.amazonaws.com:9098,broker-2.msk.amazonaws.com:9098
KAFKA_SASL_MECHANISM=oauthbearer
KAFKA_SECURITY_PROTOCOL=SASL_SSL

# OpenSearch
OPENSEARCH_URL=https://search-xxxxx.region.es.amazonaws.com
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# Auth / RBAC
KEYCLOAK_ISSUER=https://id.ahla.com/realms/ahla
KEYCLOAK_AUD=ahla-suite

# PDPL
PDPL_INCIDENT_QUEUE=ahla.pdpl.incidents
