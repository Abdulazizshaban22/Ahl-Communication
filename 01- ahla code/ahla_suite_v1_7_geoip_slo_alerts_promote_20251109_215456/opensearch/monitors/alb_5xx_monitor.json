{
  "type": "monitor",
  "name": "ALB 5xx spike (last 5m)",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 1,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": [
          "ahla-*"
        ],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "filter": [
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-5m"
                    }
                  }
                },
                {
                  "term": {
                    "service": "alb"
                  }
                }
              ]
            }
          },
          "aggs": {
            "errors": {
              "filter": {
                "range": {
                  "elb_status_code": {
                    "gte": 500,
                    "lte": 599
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "5xx > 50 in 5m",
      "severity": "2",
      "condition": {
        "script": {
          "source": "return ctx.results[0].aggregations.errors.doc_count > 50"
        }
      },
      "actions": [
        {
          "name": "Notify SNS",
          "destination_id": "<REPLACE-SNS-DESTINATION-ID>",
          "message_template": {
            "source": "ALB 5xx spike: {{ctx.results.0.aggregations.errors.doc_count}} in last 5m"
          }
        }
      ]
    }
  ]
}