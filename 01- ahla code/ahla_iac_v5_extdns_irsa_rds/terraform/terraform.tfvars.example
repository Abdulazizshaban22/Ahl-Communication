
name = "ahla"
region = "us-east-1"
domain = "ahla.com"
hosted_zone_id = "Z123EXAMPLE"   # <- replace with your Route53 hosted zone ID

db_instance_class = "db.m6i.large"
db_allocated_storage = 100
db_max_allocated_storage = 500
db_engine_version = "15.5"
db_username = "app_user"
db_password = "change_me_strong_password"
enable_rds_proxy = true
mobile_gateway_image_repo = "ghcr.io/ahla/mobile-gateway"
mobile_gateway_image_tag  = "latest"
