# ===== Kafka / MSK =====
KAFKA_BROKERS=redpanda:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT  # Use SASL_SSL in prod
KAFKA_SASL_MECHANISM=none          # Use OAUTHBEARER for MSK IAM
AWS_REGION=me-central-1

# ===== Gateway =====
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8085
GATEWAY_ALLOW_ORIGINS=*

# ===== Topics =====
TOPIC_ASR=aif.asr
TOPIC_EMOTION=aif.emotion
TOPIC_SUGGESTIONS=aif.suggestions
