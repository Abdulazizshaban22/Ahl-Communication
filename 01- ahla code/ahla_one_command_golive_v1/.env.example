# ====== Cluster / Cloud ======
AWS_REGION=me-south-1
ROUTE53_ZONE_ID=ZXXXXXXXXXXXX
BASE_DOMAIN=ahla.com

# ====== ACME (TLS Certificates) ======
ACME_EMAIL=admin@ahla.com

# ====== Keycloak (SSO) ======
KEYCLOAK_ISSUER=https://keycloak.ahla.com/realms/ahla
KEYCLOAK_CLIENT_ID=ahla-web
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH

# ====== NATS (WebSocket) ======
NATS_WS_USER=wsclient
NATS_WS_PASS=CHANGE_ME_STRONG
NATS_WS_PORT=9222

# ====== Database ======
DATABASE_URL=postgresql://ahla_user:STRONG_PASS@db-endpoint:5432/ahla

# ====== Images (اختياري لو مخصص) ======
REGISTRY=ghcr.io/YOUR_ORG/ahla
NOTES_IMG=${REGISTRY}/notes-web:latest
BOOK_IMG=${REGISTRY}/book-web:latest
GRAPH_IMG=${REGISTRY}/graph-web:latest
DOTE_IMG=${REGISTRY}/dote-web:latest
DASH_IMG=${REGISTRY}/dash-web:latest
CONTENT_IMG=${REGISTRY}/content-api:latest
COLLAB_IMG=${REGISTRY}/collab-gateway:latest
