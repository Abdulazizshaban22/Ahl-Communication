# ---------- Database ----------
DATABASE_URL="postgresql://ahla:ahla@db:5432/ahla?schema=public"

# ---------- Auth.js v5 ----------
AUTH_SECRET="replace-with-long-random"
AUTH_URL="http://localhost"

# ---------- SMTP ----------
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="no-reply@example.com"
SMTP_PASS="password"
SMTP_FROM="Ahla <no-reply@example.com>"

# ---------- S3 / MinIO ----------
S3_ENDPOINT="http://minio:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="ahla"
S3_FORCE_PATH_STYLE="true"

# ---------- ONLYOFFICE ----------
ONLYOFFICE_URL="http://onlyoffice:80"
ONLYOFFICE_JWT_SECRET="replace-with-long-random"

# ---------- WebSocket ----------
CHAT_WS_URL="ws://localhost/ws/chat"
SIGNAL_WS_URL="ws://localhost/ws/signal"

# ---------- TURN (for WebRTC later) ----------
TURN_URL="turn:turn.example.com:3478"
TURN_USERNAME="user"
TURN_CREDENTIAL="pass"

# ---------- Seed ----------
ADMIN_EMAIL="admin@ahla.local"
ADMIN_PASSWORD="changeme123"
