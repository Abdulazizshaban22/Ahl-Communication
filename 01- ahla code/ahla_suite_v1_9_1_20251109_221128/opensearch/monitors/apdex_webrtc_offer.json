{
  "type": "monitor",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 5,
      "unit": "MINUTES"
    }
  },
  "triggers": [
    {
      "name": "Apdex breach",
      "severity": "2",
      "condition": {
        "script": {
          "lang": "painless",
          "source": "double S=ctx.results[0].aggregations.sat.doc_count; double T=ctx.results[0].aggregations.tol.doc_count; double N=ctx.results[0].aggregations.total.value; if(N==0) return false; double apdex=(S+0.5*T)/N; return apdex<0.85;"
        }
      },
      "actions": [
        {
          "name": "Notify SNS",
          "destination_id": "<REPLACE-SNS-DESTINATION-ID>",
          "message_template": {
            "source": "Apdex breach on route"
          }
        }
      ]
    }
  ],
  "name": "Apdex alb /webrtc/offer (1h)",
  "inputs": [
    {
      "search": {
        "indices": [
          "ahla-*"
        ],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "filter": [
                {
                  "term": {
                    "service.keyword": "alb"
                  }
                },
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-1h"
                    }
                  }
                },
                {
                  "wildcard": {
                    "request_url": "*/webrtc/offer*"
                  }
                }
              ]
            }
          },
          "aggs": {
            "total": {
              "value_count": {
                "field": "target_processing_time"
              }
            },
            "sat": {
              "filter": {
                "range": {
                  "target_processing_time": {
                    "lte": 1.0
                  }
                }
              }
            },
            "tol": {
              "filter": {
                "range": {
                  "target_processing_time": {
                    "gt": 1.0,
                    "lte": 4.0
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}