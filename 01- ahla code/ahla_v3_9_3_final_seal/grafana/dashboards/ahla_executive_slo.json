{
  "title": "Ahla \u2014 Executive SLO",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "Platform Health",
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "H",
          "expression": "100 - (SEARCH('{AWS/ApplicationELB} MetricName=\"HTTPCode_Target_5XX_Count\"','Sum',300) / SEARCH('{AWS/ApplicationELB} MetricName=\"RequestCount\"','Sum',300))*100"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Apdex (Chat)",
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "namespace": "Ahla/Chat",
          "metricName": "Apdex",
          "dimensions": {
            "Service": "chat"
          },
          "period": "60",
          "stats": [
            "Average"
          ],
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Apdex (Meet)",
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "B",
          "namespace": "Ahla/Meet",
          "metricName": "Apdex",
          "dimensions": {
            "Service": "meet"
          },
          "period": "60",
          "stats": [
            "Average"
          ],
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (All)",
      "id": 4,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "L",
          "namespace": "AWS/ApplicationELB",
          "metricName": "TargetResponseTime",
          "dimensions": {
            "LoadBalancer": "*",
            "TargetGroup": "*"
          },
          "period": "60",
          "stats": [
            "p95"
          ],
          "datasource": {
            "type": "cloudwatch",
            "uid": "cloudwatch"
          }
        }
      ]
    },
    {
      "type": "state-timeline",
      "title": "Composite Service Alarms",
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "refId": "C1",
          "expression": "SEARCH('{AWS/CloudWatch} AlarmName=\"ahla-slo-comp-chat\"','Average',60)"
        },
        {
          "refId": "C2",
          "expression": "SEARCH('{AWS/CloudWatch} AlarmName=\"ahla-slo-comp-meet\"','Average',60)"
        },
        {
          "refId": "C3",
          "expression": "SEARCH('{AWS/CloudWatch} AlarmName=\"ahla-slo-comp-drive\"','Average',60)"
        },
        {
          "refId": "C4",
          "expression": "SEARCH('{AWS/CloudWatch} AlarmName=\"ahla-slo-comp-mail\"','Average',60)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Platform Degraded (Any)",
