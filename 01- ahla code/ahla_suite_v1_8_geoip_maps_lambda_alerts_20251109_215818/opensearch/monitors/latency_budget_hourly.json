{
  "type": "monitor",
  "name": "Latency budget burn (hourly)",
  "enabled": true,
  "schedule": {
    "period": {
      "interval": 10,
      "unit": "MINUTES"
    }
  },
  "inputs": [
    {
      "search": {
        "indices": [
          "ahla-*"
        ],
        "query": {
          "size": 0,
          "query": {
            "bool": {
              "filter": [
                {
                  "range": {
                    "@timestamp": {
                      "gte": "now-1h"
                    }
                  }
                },
                {
                  "term": {
                    "service": "alb"
                  }
                }
              ]
            }
          },
          "aggs": {
            "over": {
              "filter": {
                "range": {
                  "target_processing_time": {
                    "gt": 1.0
                  }
                }
              }
            },
            "total": {
              "value_count": {
                "field": "target_processing_time"
              }
            }
          }
        }
      }
    }
  ],
  "triggers": [
    {
      "name": "Hourly burn > 5%",
      "severity": "2",
      "condition": {
        "script": {
          "lang": "painless",
          "source": "double o=ctx.results[0].aggregations.over.doc_count; double n=ctx.results[0].aggregations.total.value; return n>100 && (o/n)>0.05;"
        }
      },
      "actions": [
        {
          "name": "Notify SNS",
          "destination_id": "<REPLACE-SNS-DESTINATION-ID>",
          "message_template": {
            "source": "Hourly latency budget burn > 5%"
          }
        }
      ]
    }
  ]
}