{
  "id": null,
  "uid": "ahla-geo-ksa",
  "title": "Ahla — KSA Choropleth (Regions/Cities) + Markers",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "type": "textbox",
        "name": "COUNTRY",
        "label": "Country ISO (e.g., SA)",
        "query": "SA",
        "current": {
          "text": "SA",
          "value": "SA"
        }
      },
      {
        "type": "textbox",
        "name": "REGION",
        "label": "Region ISO (e.g., SA-XX)",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      },
      {
        "type": "textbox",
        "name": "CITY",
        "label": "City name contains",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      },
      {
        "type": "textbox",
        "name": "SERVICE",
        "label": "Service",
        "query": "alb",
        "current": {
          "text": "alb",
          "value": "alb"
        }
      },
      {
        "type": "textbox",
        "name": "ROUTE",
        "label": "Route contains",
        "query": "",
        "current": {
          "text": "",
          "value": ""
        }
      },
      {
        "type": "textbox",
        "name": "T",
        "label": "Apdex T (sec)",
        "query": "0.5",
        "current": {
          "text": "0.5",
          "value": "0.5"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "geomap",
      "title": "KSA Regions — Choropleth (24h)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 15
      },
      "targets": [
        {
          "refId": "B",
          "query": "service.keyword: \"${SERVICE}\" AND @timestamp:[now-24h TO now] AND ip2geo.country_iso_code.keyword:\"${COUNTRY}\" AND request_url:\"${ROUTE}\""
        }
      ],
      "options": {
        "basemap": {
          "type": "carto",
          "config": {
            "theme": "auto",
            "showLabels": true
          }
        },
        "layers": [
          {
            "name": "KSA Regions",
            "type": "geojson-dynamic",
            "config": {
              "geojsonUrl": "${KSA_GEOJSON_URL}",
              "join": {
                "featureKey": "region_iso_code",
                "dataKey": "ip2geo.region_iso_code.keyword",
                "valueField": "Count"
              },
              "style": {
                "colorScheme": "RdYlBu",
                "opacity": 0.8,
                "legend": true
              }
            },
            "data": {
              "queryRefId": "B",
              "transform": "terms",
              "field": "ip2geo.region_iso_code.keyword",
              "size": 200
            }
          }
        ]
      }
    },
    {
      "type": "geomap",
      "title": "City Markers — Top UA/URI (24h)",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 16
      },
      "targets": [
        {
          "refId": "A",
          "query": "service.keyword: \"${SERVICE}\" AND @timestamp:[now-24h TO now] AND ip2geo.country_iso_code.keyword:\"${COUNTRY}\" AND request_url:\"${ROUTE}\" AND ip2geo.city_name:\"${CITY}\""
        }
      ],
      "options": {
        "basemap": {
          "type": "osm-standard",
          "config": {}
        },
        "layers": [
          {
            "name": "Clients",
            "type": "markers",
            "config": {
              "locationMode": "auto",
              "textLabelField": "user_agent",
              "tooltip": {
                "enabled": true,
                "mode": "fields",
                "extraFields": [
                  "request_url",
                  "client_ip",
                  "target_status_code",
                  "ip2geo.city_name",
                  "ip2geo.region_iso_code"
                ]
              }
            },
            "data": {
              "queryRefId": "A"
            }
          }
        ]
      }
    }
  ]
}