# --- Global ---
TZ=Asia/Riyadh
NODE_ENV=development

# --- Reverse Proxy ---
PUBLIC_ORIGIN=http://localhost:8080

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_USER=ahla
POSTGRES_PASSWORD=ahla
POSTGRES_DB=ahla

# --- MinIO (S3 dev) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=ahla
MINIO_SECRET_KEY=ahla12345
MINIO_BUCKET=ahla-drive

# --- AWS (prod placeholders) ---
AWS_REGION=me-central-1
AWS_S3_BUCKET=your-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- SMTP (dev uses Ethereal if empty) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- TURN ---
TURN_PUBLIC_IP=127.0.0.1
TURN_PORT=3478
TURN_USER=ahla
TURN_PASS=ahlaTurnPass

# --- Keycloak (dev) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=ahla
KEYCLOAK_CLIENT_ID=ahla-web
KEYCLOAK_CLIENT_SECRET=devsecret
